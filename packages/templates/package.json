{
  "name": "@unified-product-graph/templates",
  "version": "0.17.4",
  "description": "Entity templates for the Unified Product Graph: start from proven patterns, not blank pages",
  "license": "MIT",
  "author": "The Product Creator <hello@theproductcreator.com>",
  "homepage": "https://unifiedproductgraph.org",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "upg",
    "unified-product-graph",
    "templates",
    "product-management",
    "saas",
    "marketplace",
    "mobile",
    "oss",
    "agency"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unified-product-graph/templates.git"
  },
  "bugs": {
    "url": "https://github.com/unified-product-graph/templates/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@unified-product-graph/core": "*",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
